<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  {!! meta !!}
  <style>
    /* VitePress Theme CSS */
    {!! customCSS !!}
  </style>
</head>
<body>
  <div class="Layout">
    <!-- BPNav - Header -->
    <header class="BPNav">
      <div class="BPNavBar">
        <div class="BPNavBarStart">
          <a href="/" class="BPNavBarTitle">{{ title }}</a>
        </div>
        <div class="BPNavBarEnd">
          <div class="BPNavBarMenu">
            {!! nav !!}
          </div>
        </div>
      </div>
    </header>

    <main class="BPHome">
      {!! content !!}
    </main>
  </div>
</body>
</html>
